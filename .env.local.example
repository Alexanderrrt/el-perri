# El Perri — Environment Variables for Local Development
#
# SECURITY:
# 1. Copy this file to .env.local (git will ignore it)
# 2. Fill in REAL values for your local development only
# 3. NEVER commit .env.local or any secrets to git
# 4. NEVER share .env.local files via email or chat
# 5. Use different secrets in staging and production
#
# For production deployment:
# - Use GitHub Secrets (Settings > Secrets and variables > Actions)
# - Or use your hosting platform's environment variable management
# - Always use unique, strong secrets (min 32 characters)

# ============================================
# NODE & NEXT.js
# ============================================
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ============================================
# DATABASE
# ============================================
DATABASE_URL=mysql://root:password@localhost:3306/el_perri
# Example: mysql://user:password@hostname:3306/database_name
# Or PostgreSQL: postgresql://user:password@hostname:5432/database_name

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-here-min-32-chars

# Admin 2FA Secret (for demo, use: JBSWY3DPEBLW64TMMQ======)
ADMIN_2FA_SECRET=JBSWY3DPEBLW64TMMQ======

# Session timeout (milliseconds)
SESSION_TIMEOUT=3600000  # 1 hour

# Password hashing salt rounds (bcrypt)
BCRYPT_ROUNDS=10

# ============================================
# EMAIL SERVICE
# ============================================
# SendGrid API Key (get from https://sendgrid.com)
SENDGRID_API_KEY=SG.your-api-key-here

# Email sender address
EMAIL_FROM=noreply@elperrilatinfood.com
EMAIL_FROM_NAME=El Perri Latin Food

# Email support address
EMAIL_SUPPORT=support@elperrilatinfood.com

# ============================================
# PAYMENT PROCESSING
# ============================================
# Stripe API Keys (get from https://stripe.com)
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
STRIPE_PUBLIC_KEY=pk_test_your-public-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Or Square (alternative payment processor)
SQUARE_ACCESS_TOKEN=your-square-token
SQUARE_LOCATION_ID=your-location-id

# ============================================
# LOGGING & MONITORING
# ============================================
# Log level: debug, info, warn, error
LOG_LEVEL=debug

# Sentry (error tracking) — optional
SENTRY_DSN=https://your-sentry-project-id@sentry.io/project-id

# ============================================
# MARKETING & ANALYTICS
# ============================================
# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Mailchimp (for marketing lists)
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_LIST_ID=your-mailchimp-list-id

# ============================================
# GDPR & PRIVACY
# ============================================
# Data retention policies (days)
GUEST_DATA_RETENTION_DAYS=180  # Guest data deleted after 6 months
REGISTERED_DATA_RETENTION_DAYS=2555  # Registered user data kept for 7 years (for tax)
AUDIT_LOG_RETENTION_DAYS=2555  # Keep audit logs for 7 years

# GDPR Deletion grace period (days)
GDPR_DELETION_GRACE_PERIOD_DAYS=30

# Email for privacy/compliance requests
PRIVACY_EMAIL=privacy@elperrilatinfood.com

# ============================================
# EXTERNAL SERVICES (OPTIONAL)
# ============================================
# Delivery Service Integration
DELIVERY_SERVICE_API_KEY=  # For DoorDash, UberEats, etc.

# SMS Service (Twilio) — optional
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Debug mode (verbose logging)
DEBUG=true

# Disable email sending in dev (log to console instead)
EMAIL_DEBUG_MODE=true

# Use mock payment processor (no real charges)
PAYMENT_MOCK_MODE=true

# Auto-seed database with test data on startup
AUTO_SEED_DATABASE=true
