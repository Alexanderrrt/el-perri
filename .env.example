# ============================================================
# El Perri — environment variables (authoritative template)
# Copy to .env.local for local dev; set the same keys in Vercel
# (Project → Settings → Environment Variables) for Production/Preview.
# ============================================================

# --- Supabase (live database + real-time sync) ---
# Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
# Service-role key — server-side ONLY (bypasses RLS). Never expose to the browser.
# Used by server routes for privileged reads/writes.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# --- Admin login (single admin) ---
# proxy.ts verifies an HMAC-signed session cookie issued at /api/auth/admin-login
ADMIN_USERNAME=your-admin-username
ADMIN_PIN=0000
ADMIN_NAME=El Perri Admin
# Long random secret used to sign the admin_session cookie (e.g. `openssl rand -hex 32`)
ADMIN_TOKEN_SECRET=change-me-to-a-long-random-hex-string

# --- Email service (Resend) — sends the daily lunch email ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender (set after verifying your domain in Resend). Until then,
# Resend's test sender only delivers to your own account email.
EMAIL_FROM=El Perri <almuerzo@tudominio.com>
# Where catering quote requests (/api/catering) are delivered. If unset, the
# form falls back to a prefilled WhatsApp message — no leads are lost.
CATERING_EMAIL=owner@tudominio.com

# --- Square (in-site checkout — Square is strictly the payment processor) ---
# developer.squareup.com -> your app -> Sandbox (test first) or Production tab.
# Server-only: never expose SQUARE_ACCESS_TOKEN to the browser.
SQUARE_ACCESS_TOKEN=EAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SQUARE_LOCATION_ID=Lxxxxxxxxxxxxx
SQUARE_ENVIRONMENT=sandbox
# Browser-safe (NEXT_PUBLIC_) — used to load the Web Payments SDK card field.
NEXT_PUBLIC_SQUARE_APP_ID=sandbox-sq0idb-xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SQUARE_LOCATION_ID=Lxxxxxxxxxxxxx
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox
# Without these set, checkout still works in "pay at pickup" mode.

# --- LLM (AI behind the WhatsApp ordering bot) ---
# Any OpenAI-compatible endpoint with function/tool calling works. Server-only,
# never expose to the browser. Paste the key directly here / in Vercel.
#
# Default: Groq free tier (fast ~1-3s replies, no credit card).
#   console.groq.com -> API Keys -> Create API Key (key starts with "gsk_").
LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-120b
# Other providers (same three vars, just change the values):
#   DeepSeek direct: key sk-...,   base https://api.deepseek.com,               model deepseek-chat
#   NVIDIA:          key nvapi-..., base https://integrate.api.nvidia.com/v1,   model deepseek-ai/deepseek-v4-pro (slow on free tier)

# --- WhatsApp Cloud API (Meta) — powers the AI ordering bot ---
# developer.facebook.com -> My Apps -> Create App -> add the WhatsApp product.
# See docs/REMAINING-HANDOFF.md for the full step-by-step setup.
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Used only to verify Meta's HMAC signature on incoming webhook requests —
# rejects spoofed requests that could otherwise create fake orders.
WHATSAPP_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# A string you make up yourself, entered when registering the webhook URL in
# the Meta dashboard (not a secret from Meta).
WHATSAPP_VERIFY_TOKEN=choose-any-long-random-string
# Optional, comma-separated phone numbers (E.164 digits, no "+"). While set,
# only these numbers get bot replies — use this during testing. Remove it
# (or leave unset) to let the bot respond to everyone once you go live.
WHATSAPP_ALLOWLIST=19834564801

# --- Cron protection ---
# Secret that protects the daily-lunch cron route. Make up a long random
# string; set the SAME value in Vercel. Vercel Cron sends it automatically.
CRON_SECRET=change-me-to-a-long-random-string

# --- App settings ---
NEXT_PUBLIC_API_URL=http://localhost:3000
