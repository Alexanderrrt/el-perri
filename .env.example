# ============================================================
# El Perri — environment variables (authoritative template)
# Copy to .env.local for local dev; set the same keys in Vercel
# (Project → Settings → Environment Variables) for Production/Preview.
# ============================================================

# --- Supabase (live database + real-time sync) ---
# Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
# Service-role key — server-side ONLY (bypasses RLS). Never expose to the browser.
# Used by server routes for privileged reads/writes.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# --- Admin login (single admin) ---
# proxy.ts verifies an HMAC-signed session cookie issued at /api/auth/admin-login
ADMIN_USERNAME=your-admin-username
ADMIN_PIN=0000
ADMIN_NAME=El Perri Admin
# Long random secret used to sign the admin_session cookie (e.g. `openssl rand -hex 32`)
ADMIN_TOKEN_SECRET=change-me-to-a-long-random-hex-string

# --- Email service (Resend) — sends the daily lunch email ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender (set after verifying your domain in Resend). Until then,
# Resend's test sender only delivers to your own account email.
EMAIL_FROM=El Perri <almuerzo@tudominio.com>
# Where catering quote requests (/api/catering) are delivered. If unset, the
# form falls back to a prefilled WhatsApp message — no leads are lost.
CATERING_EMAIL=owner@tudominio.com

# --- Cron protection ---
# Secret that protects the daily-lunch cron route. Make up a long random
# string; set the SAME value in Vercel. Vercel Cron sends it automatically.
CRON_SECRET=change-me-to-a-long-random-string

# --- App settings ---
NEXT_PUBLIC_API_URL=http://localhost:3000
